# ============================================================================
# PaidProof — environment variables
# Copy this file to `.env` and fill in the blanks.
# Do NOT commit the populated `.env`.
# ============================================================================

# --- LLM ---------------------------------------------------------------------
OPENAI_API_KEY=                          # used by Lead Verifier + AestheticJudge (gpt-4o vision)
ANTHROPIC_API_KEY=                       # optional fallback

# --- Chain target ------------------------------------------------------------
# Pick one of: localhost (hardhat node) | goat-testnet3 | goat-mainnet
CHAIN_TARGET=localhost

# Localhost (hardhat node — `npm run node:local`)
LOCAL_RPC_URL=http://127.0.0.1:8545
LOCAL_CHAIN_ID=31337

# GOAT Testnet3 (Bitcoin-secured zkRollup)
GOAT_RPC_URL=https://rpc.testnet3.goat.network
GOAT_CHAIN_ID=48816
GOAT_EXPLORER=https://explorer.testnet3.goat.network

# Hardhat deployer key (also funds local demo). Default = Hardhat account #0.
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- PaidProof contracts (populated by `npm run deploy:local|goat`) ----------
PAIDPROOF_REGISTRY_ADDRESS=
PAIDPROOF_ESCROW_ADDRESS=
PAIDPROOF_USDC_ADDRESS=

# --- Agent wallets (one private key per agent) -------------------------------
# `npm run register:local` will populate sane defaults for you using
# Hardhat account #1..#6.
FOREMAN_PRIVATE_KEY=                     # Lead Verifier — only wallet authorised to release escrow
RESEARCHER_PRIVATE_KEY=                  # FileSpec specialist
WRITER_PRIVATE_KEY=                      # ColorVision specialist
AESTHETIC_PRIVATE_KEY=                   # AestheticJudge specialist

# Demo participants (used by dashboard to sign fund/markDelivered)
CLIENT_PRIVATE_KEY=
FREELANCER_PRIVATE_KEY=

# --- Agent IDs on AgentRegistry (populated by `npm run register:*`) ----------
FOREMAN_AGENT_ID=                        # Lead Verifier
RESEARCHER_AGENT_ID=                     # FileSpec
WRITER_AGENT_ID=                         # ColorVision
AESTHETIC_AGENT_ID=                      # AestheticJudge
CLIENT_AGENT_ID=
FREELANCER_AGENT_ID=

# --- Agent wallet addresses (payTo for x402 challenges) ----------------------
FOREMAN_WALLET_ADDRESS=
RESEARCHER_WALLET_ADDRESS=
WRITER_WALLET_ADDRESS=
AESTHETIC_WALLET_ADDRESS=
CLIENT_WALLET_ADDRESS=
FREELANCER_WALLET_ADDRESS=

# --- Local service URLs ------------------------------------------------------
FOREMAN_URL=http://localhost:3100
RESEARCHER_URL=http://localhost:3101
WRITER_URL=http://localhost:3102
AESTHETIC_URL=http://localhost:3103
DASHBOARD_URL=http://localhost:3000

# --- Specialist registry (Lead Verifier reads this for static routing) -------
# JSON array. Each entry: { "url": string, "skills": string[] }
SPECIALIST_REGISTRY=[{"url":"http://localhost:3101","skills":["verify.filespec"]},{"url":"http://localhost:3102","skills":["verify.colorvision"]},{"url":"http://localhost:3103","skills":["verify.aesthetic"]}]

# --- x402 --------------------------------------------------------------------
X402_MODE=mock                           # mock | local | facilitator
# mock        : zero-config demo, synthesised tx hashes
# local       : real USDC transfer + on-chain receipt verification
# facilitator : reserved for full x402 v2 server flow
X402_NETWORK=paidproof-local
X402_FACILITATOR_URL=https://x402.org/facilitator

# --- Misc --------------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=development
