# ───────────── RefundRex env ─────────────
# Most of these are optional in DEMO_MODE. The app runs end-to-end with mocks
# when no real keys are present so judges always see a working demo.

# Master switch — when true, all on-chain & merchant interactions are
# simulated locally with realistic latency + fake-but-deterministic hashes.
DEMO_MODE=true

# ── GOAT Network ──
GOAT_RPC_URL=https://rpc.goat.network
GOAT_CHAIN_ID=2345
GOAT_EXPLORER_URL=https://explorer.goat.network

# ── Agent wallet (generated by the agent on first boot if blank) ──
# NEVER commit real keys. Use `node scripts/wallet.ts` to mint one.
AGENT_WALLET_ADDRESS=
AGENT_WALLET_PRIVATE_KEY=

# ── ERC-8004 ──
ERC8004_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_AGENT_NAME=refundrex_bot
ERC8004_AGENT_URI=https://refundrex.xyz/agent.json
ERC8004_AGENT_ID=

# ── x402 (GOAT Network Merchant Portal) ──
GOATX402_API_URL=https://x402-merchant.goat.network/api
GOATX402_API_KEY=
GOATX402_API_SECRET=
GOATX402_MERCHANT_ID=refundrex
GOATX402_RECEIVING_WALLET=
GOATX402_TOKEN=USDC
GOATX402_AMOUNT=0.10
GOATX402_USDC_CONTRACT=0x3022b87ac063DE95b1570F46f5e470F8B53112D8

# ── OpenClaw / ClawUp ──
OPENCLAW_AGENT_ID=
OPENCLAW_PAIRING_CODE=
OPENCLAW_TELEGRAM_BOT_TOKEN=

# ── Optional LLM (the agent will fall back to deterministic templates if blank) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=mock          # mock | openai | anthropic
LLM_MODEL=deepseek/deepseek-chat

# ── App ──
NEXT_PUBLIC_APP_NAME=RefundRex
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true
